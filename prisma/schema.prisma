generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id       String @id @default(cuid())
  wallet   String @unique
  username String?
}

model Market {
  id          String   @id @default(cuid())
  title       String
  description String
  category    String
}